generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Pet {
  id             Int           @id @default(autoincrement())
  name           String?       @db.VarChar(100)
  hunger         Int           @default(100)
  energy         Int           @default(100)
  happiness      Int           @default(100)
  hygiene        Int           @default(100)
  life           Int           @default(100)
  appearance     String?
  lastUpdate     DateTime      @default(now())
  playCooldown   DateTime?
  sleepStartedAt DateTime?
  workSessions   WorkSession[] @relation("PetWorkSessions")

  @@map("pets")
}

model Item {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  effect    Json?
  price     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("items")
}

model GameScore {
  id        Int      @id @default(autoincrement())
  game      String
  player    String
  score     Int
  createdAt DateTime @default(now())

  @@map("game_scores")
}

model Purchase {
  id       Int      @id @default(autoincrement())
  petId    Int
  itemId   Int
  quantity Int      @default(1)
  boughtAt DateTime @default(now())

  @@map("purchases")
}

model Person {
  id                Int                @id @default(autoincrement())
  name              String
  role              String?
  code              String             @unique
  createdAt         DateTime           @default(now())
  coins             Int                @default(0)
  totalTimeSeconds  Int                @default(0)
  bet_votes         bet_votes[]
  bets              bets[]
  companionSessions CompanionSession[] @relation("PersonCompanionSessions")
  samuraiSessions   SamuraiSession[]   @relation("PersonSamuraiSessions")
  workSessions      WorkSession[]      @relation("PersonWorkSessions")

  @@map("people")
}

model CompanionSession {
  id          Int      @id @default(autoincrement())
  personId    Int
  code        String
  startedAt   DateTime @default(now())
  lastTickAt  DateTime @default(now())
  active      Boolean  @default(true)
  coinsEarned Int      @default(0)
  person      Person   @relation("PersonCompanionSessions", fields: [personId], references: [id])

  @@map("companion_sessions")
}

model WorkSession {
  id         Int      @id @default(autoincrement())
  petId      Int
  personId   Int
  startedAt  DateTime @default(now())
  lastTickAt DateTime @default(now())
  active     Boolean  @default(true)
  person     Person   @relation("PersonWorkSessions", fields: [personId], references: [id])
  pet        Pet      @relation("PetWorkSessions", fields: [petId], references: [id])

  @@map("work_sessions")
}

model SamuraiSession {
  id           Int      @id @default(autoincrement())
  personId     Int
  petId        Int
  startedAt    DateTime @default(now())
  lastClickAt  DateTime @default(now())
  active       Boolean  @default(true)
  totalSeconds Int      @default(0)
  person       Person   @relation("PersonSamuraiSessions", fields: [personId], references: [id])

  @@map("samurai_sessions")
}

model TeamPlayRoom {
  id           String   @id
  game         String
  players      Json
  turn         String
  winner       String?
  state        Json
  rematchVotes Json     @default("[]")
  hostPersonId Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("team_play_rooms")
}

model BugReport {
  id          Int             @id @default(autoincrement())
  title       String
  description String
  severity    String          @default("medium")
  status      String          @default("open")
  reporter    String?
  email       String?
  url         String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  files       BugReportFile[]

  @@map("bug_reports")
}

model BugReportFile {
  id          Int       @id @default(autoincrement())
  bugReportId Int
  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int
  createdAt   DateTime  @default(now())
  bugReport   BugReport @relation(fields: [bugReportId], references: [id], onDelete: Cascade)

  @@index([bugReportId])
  @@map("bug_report_files")
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  level     String   @default("info")
  message   String
  context   Json?
  source    String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
  @@map("system_logs")
}

model bet_votes {
  id        Int      @id @default(autoincrement())
  betId     Int
  personId  Int
  optionIdx Int
  coins     Int      @default(0)
  createdAt DateTime @default(now())
  bets      bets     @relation(fields: [betId], references: [id], onDelete: Cascade)
  people    Person   @relation(fields: [personId], references: [id])

  @@unique([betId, personId, optionIdx])
}

model bets {
  id          Int         @id @default(autoincrement())
  title       String
  description String?
  creatorId   Int
  options     Json        @default("[]") @db.Json
  status      String      @default("active")
  endsAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  bet_votes   bet_votes[]
  creator     Person      @relation(fields: [creatorId], references: [id])
}
